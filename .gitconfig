[user]
	name = upinetree
	email = upinetree@gmail.com

[color]
	ui = auto

[core]
	excludesfile = ~/.gitignore
	precomposeunicode = true
	quotepath = false
	editor = vim
	pager = delta

[commit]
	verbose = true

[fetch]
	prune = true

[pull]
	rebase = true
	prune = true

[push]
	default = current
	autoSetupRemote = true

[rebase]
	autostash = true # conflict がつらかったら外す

[merge]
	conflictstyle = zdiff3

[branch]
	sort = -committerdate

[credential]
	helper = osxkeychain

[alias]
	# branch manipulation
	b = branch
	co = checkout
	coo = "!git ls-files --modified | fzf -m --cycle --preview 'git diff {} | delta' --preview-window 'up:80%' | xargs git co && git s"
	sw = switch
	main = "!git symbolic-ref refs/remotes/origin/HEAD | cut -d'/' -f4"
	sync-main = "!git remote set-head origin --auto"
	sm = "!git switch $(git main)"
	f = fetch
	fm = "!git fetch origin $(git main)"
	fmr = "!git fm && git rebase origin/$(git main)"
	p = pull
	b-tidy = "!git branch --merged | grep -Ev $(git main) | xargs git branch -d"
	b-select = "!git branch | grep -v '^[*]' | sed 's/^ *//' | fzf -m --cycle --preview \"git show {} | delta\" --preview-window 'up:80%'"
	b-delete = "!f() { BRANCHES=$(git b-select); [ -z \"$BRANCHES\" ] && return; echo \"$BRANCHES\"; printf 'Delete these branches? [y/N] '; read ANS; [ \"$ANS\" = y ] && echo \"$BRANCHES\" | xargs git branch -D; }; f"

	aicommit = "!f() { COMMITMSG=$(claude --no-session-persistence --print 'Generate ONLY a one-line Git commit message in English using imperative mood. The message should summarize what was changed and why, based strictly on the contents of `git diff --cached`. DO NOT add an explanation or a body. Output ONLY the commit summary line.'); git commit -m \"$COMMITMSG\" -e; }; f"

	# snapshotting
	s = status -sbu
	a = add -p
	aa = "!git ls-files --modified | fzf -m --cycle --preview 'git diff {} | delta' --preview-window 'up:80%' | xargs git add && git s"
	ao = "!git ls-files --others --exclude-standard | fzf -m --cycle --preview 'bat --style=numbers --color=always --line-range :500 {}' --preview-window 'up:80%' | xargs git add && git s"
	ci = commit
	cm = commit -m
	ca = commit --amend
	can = commit --amend --no-edit
	r = reset
	rr = "!git dfc --name-only | fzf -m --cycle --preview 'git dfc {} | delta' --preview-window 'up:80%' | xargs git reset"
	res = restore
	pop = stash pop

	# sharing
	pushf = push --force-with-lease

	# inspection
	df = diff --color
	dfc = diff --color --cached
	l = log --color --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
	lg = l --graph
	lga = lg --all
	lm = l --merges
	ls = log --stat
	lp = log -p --color
	sh = show --color

	# github
	open = "!gh repo view -w"
	openpr = "!gh pr view -w"

[ghq]
	# ghq.root: the last one becomes primary one.
	root = ~/go/src
	root = ~/repo

[pager]
	branch = false

[interactive]
	diffFilter = delta --color-only

[diff]
	compactionHeuristic = true
	colorMoved = default
	algorithm = histogram

[delta]
	plus-style = syntax auto
	minus-style = syntax auto
	syntax-theme = Dracula
	navigate = true

[url "ssh://git@github.com/heyinc/"]
	insteadOf = https://github.com/heyinc/
[init]
	defaultBranch = main
