{
  "env": {
    "CLAUDECODE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(git add:*)",
      "Bash(git config --get:*)",
      "Bash(git config --get-all:*)",
      "Bash(git config --get-regexp:*)",
      "Bash(git config --list:*)",
      "Bash(git config -l:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(gh api:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(curl:*)",
      "Bash(gem dependency:*)",
      "Bash(gem fetch:*)",
      "Bash(gem list:*)",
      "Bash(gem search:*)",
      "Bash(gem spec:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle install:*)",
      "Bash(bundle show:*)",
      "Bash(bundle info:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(rmdir:*)",
      "Bash(diskutil:*)",
      "Bash(dd:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chgrp:*)",
      "Bash(launchctl:*)",
      "Bash(umount:*)",
      "Bash(nvram:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Read(.env.*)",
      "Read(mise.local.toml)",
      "Read(.mise.local.toml)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(*.key)"
    ],
    "ask": [
      "Bash(sh -c:*)",
      "Bash(bash -c:*)",
      "Bash(zsh -c:*)",
      "Bash(brew:*)",
      "Bash(gh api *--method POST*:*)",
      "Bash(gh api *--method PATCH*:*)",
      "Bash(gh api *--method PUT*:*)",
      "Bash(gh api *--method DELETE*:*)",
      "Bash(gh api *-X POST*:*)",
      "Bash(gh api *-X PATCH*:*)",
      "Bash(gh api *-X PUT*:*)",
      "Bash(gh api *-X DELETE*:*)",
      "Bash(git checkout:*)",
      "Bash(git config --global:*)",
      "Bash(git config --system:*)",
      "Bash(git switch:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(curl *-X POST*)",
      "Bash(curl *--request POST*)",
      "Bash(curl *-d *)",
      "Bash(curl *--data*)",
      "Bash(curl *-F *)",
      "Bash(curl *--form *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/report-session-trigger.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"asking...\" with title \"Claude Code\" sound name \"Submarine\"'"
          },
          {
            "type": "command",
            "command": "ruby \"$HOME/.claude/hooks/voicevox-speak.rb\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"done!\" with title \"Claude Code\" sound name \"Glass\"'"
          },
          {
            "type": "command",
            "command": "ruby \"$HOME/.claude/hooks/voicevox-speak.rb\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/report-session-commit-trigger.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".rb\") or endswith(\".rake\"))' | xargs -r bundle exec rubocop --force-exclusion -A"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".md\"))' | xargs -r prettier --write"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".rb\") or endswith(\".rake\"))' >> ~/.claude/recently_edited_files.txt"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/rody/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "datadog@claude-plugins-official": true
  },
  "language": "日本語",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
