{
  "env": {
    "CLAUDECODE": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git grep:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(curl:*)",
      "Bash(gem dependency:*)",
      "Bash(gem fetch:*)",
      "Bash(gem list:*)",
      "Bash(gem search:*)",
      "Bash(gem spec:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle install:*)",
      "Bash(bundle show:*)",
      "Bash(bundle info:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(rmdir:*)",
      "Bash(diskutil:*)",
      "Bash(dd:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(chgrp:*)",
      "Bash(launchctl:*)",
      "Bash(umount:*)",
      "Bash(nvram:*)",
      "Bash(sh:*)",
      "Bash(bash:*)",
      "Bash(zsh:*)",
      "Bash(brew:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(git config:*)",
      "Read(.env.*)",
      "Read(mise.local.toml)",
      "Read(.mise.local.toml)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(*.key)"
    ],
    "ask": [
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(curl *-X POST*)",
      "Bash(curl *--request POST*)",
      "Bash(curl *-d *)",
      "Bash(curl *--data*)",
      "Bash(curl *-F *)",
      "Bash(curl *--form *)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"asking...\" with title \"Claude Code\" sound name \"Submarine\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"done!\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".rb\") or endswith(\".rake\"))' | xargs -r bundle exec rubocop --force-exclusion -A"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".md\"))' | xargs -r prettier --write"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".rb\") or endswith(\".rake\"))' >> ~/.claude/recently_edited_files.txt"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/rody/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
